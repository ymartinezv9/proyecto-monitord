[Unit]
Description=Monitord Resource Monitoring Daemon
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/bin/monitord.py
User=monitord
Group=monitord
Restart=on-failure
# Hardening
ProtectSystem=strict
ReadWritePaths=/var/log/monitord
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
